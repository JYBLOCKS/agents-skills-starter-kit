{
  "name": "agents-skills-starter-kit",
  "displayName": "AI starter kit",
  "version": "0.3.0",
  "description": "Portable starter kit for agent-driven delivery workflows with shared agents, reusable skills, and thin multi-host adapters.",
  "repository": "https://github.com/JYBLOCKS/agents-skills-starter-kit",
  "installSurface": {
    "skillsRoot": "./skills"
  },
  "sourceOfTruth": {
    "agents": "./agents",
    "skills": "./skills",
    "context": "./context",
    "rules": "./rules",
    "checklists": "./checklists",
    "runbooks": "./runbooks",
    "specs": "./specs",
    "creators": "./creators",
    "templates": "./templates",
    "adapters": "./adapters"
  },
  "hosts": [
    {
      "id": "claude-code",
      "adapter": "./adapters/claude-code",
      "install": {
        "type": "universal",
        "command": "npx skills add JYBLOCKS/agents-skills-starter-kit -a claude-code"
      }
    },
    {
      "id": "codex",
      "adapter": "./adapters/codex",
      "install": {
        "type": "native",
        "plugin": "./plugins/ai-starter-kit/.codex-plugin/plugin.json",
        "marketplace": "./.agents/plugins/marketplace.json",
        "fallbackCommand": "npx skills add JYBLOCKS/agents-skills-starter-kit -a codex"
      }
    },
    {
      "id": "gemini-cli",
      "adapter": "./adapters/gemini-cli",
      "install": {
        "type": "native-and-universal",
        "extension": "./gemini-extension.json",
        "command": "gemini extensions install https://github.com/JYBLOCKS/agents-skills-starter-kit",
        "fallbackCommand": "npx skills add JYBLOCKS/agents-skills-starter-kit -a gemini-cli"
      }
    },
    {
      "id": "cursor",
      "adapter": "./adapters/cursor",
      "install": {
        "type": "universal",
        "command": "npx skills add JYBLOCKS/agents-skills-starter-kit -a cursor"
      }
    },
    {
      "id": "windsurf",
      "adapter": "./adapters/windsurf",
      "install": {
        "type": "universal",
        "command": "npx skills add JYBLOCKS/agents-skills-starter-kit -a windsurf"
      }
    },
    {
      "id": "github-copilot",
      "adapter": "./adapters/github-copilot",
      "install": {
        "type": "universal",
        "command": "npx skills add JYBLOCKS/agents-skills-starter-kit -a github-copilot"
      }
    },
    {
      "id": "cline",
      "adapter": "./adapters/cline",
      "install": {
        "type": "universal",
        "command": "npx skills add JYBLOCKS/agents-skills-starter-kit -a cline"
      }
    },
    {
      "id": "universal",
      "adapter": "./adapters/generic",
      "install": {
        "type": "universal",
        "command": "npx skills add JYBLOCKS/agents-skills-starter-kit"
      }
    }
  ],
